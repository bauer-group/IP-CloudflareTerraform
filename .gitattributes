# =============================================================================
# Line-ending normalization
# =============================================================================
# Normalize all text files to LF in the repository and on checkout (cross-OS
# determinism). Container-relevant files (shell, Dockerfiles, Python, YAML) MUST
# stay LF — CRLF breaks shebangs and many runtimes.

# Default: treat as text, store + check out with LF on every platform.
* text=auto eol=lf

# Explicit LF for executable / runtime-sensitive files.
*.sh         text eol=lf
*.bash       text eol=lf
*.py         text eol=lf
*.tf         text eol=lf
*.hcl        text eol=lf
*.yml        text eol=lf
*.yaml       text eol=lf
*.json       text eol=lf
*.toml       text eol=lf
*.md         text eol=lf
*.env        text eol=lf
Dockerfile   text eol=lf
.env.example text eol=lf
.dockerignore text eol=lf

# Binary assets — never normalize / diff as text.
*.ico   binary
*.png   binary
*.jpg   binary
*.gz    binary
*.zip   binary
