# =============================================================================
# CloudflareTerraform — environment template
# -----------------------------------------------------------------------------
# Copy to .env and fill in. .env is gitignored; this template is the canonical
# contract. Secrets stay in the environment and are referenced by the engine at
# runtime ($${VAR} in docker-compose.yml) — they never enter the rendered config.
# =============================================================================

# ── Image ────────────────────────────────────────────────────────────────────
STACK_NAME=cloudflare
TIME_ZONE=Etc/UTC
# CLOUDFLARE_BACKUP_IMAGE=ghcr.io/bauer-group/ip-cloudflareterraform/cloudflare-backup
CLOUDFLARE_BACKUP_VERSION=latest
BACKUP_LOG_LEVEL=INFO

# ── Cloudflare API ───────────────────────────────────────────────────────────
# Scoped API token. For BACKUP use a READ-ONLY token (Zone Read, DNS Read,
# Account settings Read, Workers Read, Access Read, …). For `cloudflare apply`
# (restore) use a separate READ-WRITE token. Never commit real values.
CLOUDFLARE_API_TOKEN=
# Optional: pin to one account. Empty = inferred from the zones the token sees.
CLOUDFLARE_ACCOUNT_ID=
# "auto" = back up every zone the token can see; or a comma list of zone names.
CLOUDFLARE_ZONES=auto
# all | zone | account
CLOUDFLARE_RESOURCE_SCOPE=all
# schema  = enumerate EVERY provider resource type (maximum coverage for backup
#           & recovery; ~1000+ API calls, minutes per run) — the default.
# curated = a fast, predictable built-in allow-list (fewer calls) for quick runs.
CLOUDFLARE_RESOURCE_DISCOVERY=schema
# Requests/sec ceiling (global Cloudflare limit is 1200 req / 5 min per user).
CLOUDFLARE_THROTTLE_RPS=4

# ── Schedule ─────────────────────────────────────────────────────────────────
BACKUP_SCHEDULE_MODE=cron
BACKUP_SCHEDULE_CRON=15 3 * * *

# ── Retention (30 days + grandfather-father-son tiers) ───────────────────────
BACKUP_RETENTION_AGE_DAYS=30
BACKUP_GFS_DAILY=7
BACKUP_GFS_WEEKLY=4
BACKUP_GFS_MONTHLY=6

# ── Off-site S3 (optional — empty bucket = local-only) ───────────────────────
# S3-compatible: AWS, MinIO, Cloudflare R2, Backblaze B2, Wasabi (keep path-style).
BACKUP_S3_ENDPOINT=
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_REGION=eu-central-1
BACKUP_S3_PREFIX=cloudflare/
BACKUP_S3_FORCE_PATH_STYLE=true

# ── At-rest encryption (recommended for off-site: engine has no S3 SSE) ───────
# none | age | gpg. For age/gpg set the recipient (age public key / gpg id).
BACKUP_ENCRYPTION_MODE=none
BACKUP_ENCRYPTION_RECIPIENT=

# ── Alerting (optional) ──────────────────────────────────────────────────────
# Channels: csv of email,webhook,teams,slack,discord,ntfy,healthchecks.
# Level: errors | warnings | all.
BACKUP_ALERT_CHANNELS=
BACKUP_ALERT_LEVEL=warnings
BACKUP_ALERT_EMAIL=
BACKUP_WEBHOOK_URL=
BACKUP_WEBHOOK_SECRET=
BACKUP_TEAMS_WEBHOOK=
# Shared SMTP block (email channel)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
